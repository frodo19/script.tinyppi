                <font>font14</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">$SKIN[white.png]</texturefocus>
                <texturenofocus colordiffuse="33FFFFFF">$SKIN[white.png]</texturenofocus>
                <onup>1003</onup>
