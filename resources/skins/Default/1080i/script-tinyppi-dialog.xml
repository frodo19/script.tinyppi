<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">1001</defaultcontrol>
    <animation effect="fade" start="0" end="100" time="200" tween="cubic" easing="inout">WindowOpen</animation>
    <animation effect="fade" end="0" start="100" time="150">WindowClose</animation>
    <controls>

        <!-- Semi-transparent dark overlay (full screen) -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="CC000000">$SKIN[white.png]</texture>
        </control>

        <!-- Centered dialog panel -->
        <control type="group">
            <left>710</left>
            <top>290</top>
            <width>500</width>
            <height>500</height>

            <!-- Panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>500</width>
                <height>500</height>
                <texture colordiffuse="EE1A1A1A">$SKIN[white.png]</texture>
            </control>

            <!-- Button 1: TinyPPI -->
            <control type="button" id="1001">
                <left>30</left>
                <top>30</top>
                <width>440</width>
                <height>70</height>
                <label>TinyPPI</label>
                <font>font14</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">$SKIN[white.png]</texturefocus>
                <texturenofocus colordiffuse="33FFFFFF">$SKIN[white.png]</texturenofocus>
                <onup>1005</onup>
                <ondown>1002</ondown>
            </control>

            <!-- Button 2: Original -->
            <control type="button" id="1002">
                <left>30</left>
                <top>120</top>
                <width>440</width>
                <height>70</height>
