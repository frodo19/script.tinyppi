				<top>-1000</top>
				<width>2000</width>
				<height>2080</height>
				<control type="image">
					<texture colordiffuse="FF000000">gradient.png</texture>
				</control>
			</control>

			<!-- Group: Bottom screen -->
			<control type="group">
				<top>585</top>
				<width>1920</width>
				<height>0</height>

				<!-- Group: Video -->
				<control type="group">
					<left>30</left>
					
					<!-- Video -->
					<control type="label">
						<label>[B][UPPERCASE]$ADDON[script.tinyppi 32054][/UPPERCASE][/B]</label>
						<font>font10</font>
						<textcolor>ffededed</textcolor>
					</control>
					
					<!-- Display mode -->
					<control type="label">
						<top>35</top>
						<label>$ADDON[script.tinyppi 32000]:</label>
						<font>font10</font>
						<textcolor>e7ededed</textcolor>
					</control>
					<control type="label">
						<left>210</left>
						<top>35</top>
						<label>$INFO[Window().Property(DisplayModeVar)]</label>
						<font>font10</font>
						<textcolor>e7ededed</textcolor>
